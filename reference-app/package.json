{
  "name": "socle-reference-app",
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "build": "node utils/build.js",
    "serve": "npx serve dist --listen 3000 --single",
    "dev": "node utils/build.js && npx serve dist --listen 3000 --single",
    "dev:https": "node utils/build.js && npx serve dist --listen tcp:0.0.0.0:3000 --single --ssl-cert local.pem --ssl-key local-key.pem",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.0"
  }
}
